#!/bin/sh

set -eu

if ! git diff --quiet --ignore-submodules --; then
  echo "Push blocked: working tree has unstaged changes." >&2
  echo "Commit, stash, or discard them before pushing." >&2
  git status --short >&2
  exit 1
fi

if ! git diff --cached --quiet --ignore-submodules --; then
  echo "Push blocked: index has staged but uncommitted changes." >&2
  echo "Commit or unstage them before pushing." >&2
  git status --short >&2
  exit 1
fi

if test -n "$(git ls-files -u)"; then
  echo "Push blocked: repository has unresolved merge conflicts." >&2
  git status --short >&2
  exit 1
fi
